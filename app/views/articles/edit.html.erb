<% content_for(:title, @article.title) %>

<h1>編集</h1>

<%= form_with model: @article do |f| %>

  <div class="form-group">
    <%= f.label :title, "タイトル" %>
    <%= f.text_field :title %>
  </div>

  <div class="form-group">
    <%= f.label :content, "内容" %>
    <%= f.text_area :content %>
  </div>
  <div class="form-action">
    <%= f.submit "更新する" %>
  </div>
<% end %>
