<h1>メモ一覧</h1>
<%= form_with model: @article do |f| %>

  <div class="form-group">
    <%= f.label :title, "タイトル" %>
    <%= f.text_field :title %>
    <% @article.errors.full_messages_for(:title).each do |message| %>
      <div style="color: red; font-size: 0.8em;"><%= message %></div>
    <% end %>
  </div>

  <div class="form-group">
    <%= f.label :content, "内容" %>
    <%= f.text_area :content %>
    <% @article.errors.full_messages_for(:content).each do |message| %>
      <div style="color: red; font-size: 0.8em;"><%= message %></div>
    <% end %>
  </div>

  <div class="form-group">
    <%= f.label :category_id, "カテゴリ" %>
    <%= f.collection_select :category_id, Category.all, :id, :name, include_blank: "選択してください" %>
    <% @article.errors.full_messages_for(:category).each do |message| %>
      <div style="color: red; font-size: 0.8em;"><%= message %></div>
    <% end %>
  </div>

  <div class="form-group">
    <%= f.label "画像の投稿" %>
    <%= f.file_field :image %>
  </div>

  <div class="form-action">
    <%= f.submit "保存する" %>
  </div>
<% end %>

<% @articles.each do |article| %>
  <h2><%= link_to article.title, article_path(article.id) %></h2>
<% end %>
